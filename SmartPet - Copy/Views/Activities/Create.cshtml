@model SmartPet.Models.Activity

@{
	ViewBag.Title = "Create Activity";
}

<h2>Create Activity</h2>

@using (Html.BeginForm())
{
	@Html.AntiForgeryToken()

	<div class="form-horizontal">
		<hr />
		@Html.ValidationSummary(true, "", new { @class = "text-danger" })

		<div class="form-group">
			@Html.Label("Pet", htmlAttributes: new { @class = "control-label col-md-2" })
			<div class="col-md-10">
				@Html.DropDownList("petId", null, "-- Select Pet --", new { @class = "form-control" })
				@Html.ValidationMessageFor(model => model.petId, "", new { @class = "text-danger" })
			</div>
		</div>

		<div class="form-group">
			@Html.Label("Activity Name", htmlAttributes: new { @class = "control-label col-md-2" })
			<div class="col-md-10">
				@Html.TextBoxFor(model => model.activityName, new { @class = "form-control" })
				@Html.ValidationMessageFor(model => model.activityName, "", new { @class = "text-danger" })
			</div>
		</div>

		<div class="form-group">
			@Html.Label("Activity Date", htmlAttributes: new { @class = "control-label col-md-2" })
			<div class="col-md-10">
				@Html.TextBoxFor(model => model.activityDate, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
				@Html.ValidationMessageFor(model => model.activityDate, "", new { @class = "text-danger" })
			</div>
		</div>

		<div class="form-group">
			@Html.Label("Completed", htmlAttributes: new { @class = "control-label col-md-2" })
			<div class="col-md-10">
				<div class="checkbox">
					@Html.CheckBoxFor(model => model.completed)
					@Html.ValidationMessageFor(model => model.completed, "", new { @class = "text-danger" })
				</div>
			</div>
		</div>

		<div class="form-group">
			<div class="col-md-offset-2 col-md-10">
				<input type="submit" value="Save Activity" class="btn btn-success" />
			</div>
		</div>
	</div>
}

<div>
	@Html.ActionLink("Back to Activities Log", "Index", "Activities")
</div>