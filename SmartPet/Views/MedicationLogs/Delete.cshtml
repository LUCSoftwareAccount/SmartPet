@model SmartPet.Models.MedicationLogs

@{
	ViewBag.Title = "Delete Medication Log";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Delete Medication Log</h2>

<h3>Are you sure you want to delete this log?</h3>

<div>
	<dl class="dl-horizontal">
		<dt>Amount</dt>
		<dd>@Model.amount</dd>
		<dt>Administered At</dt>
		<dd>@Model.administeredAt.ToString("MMM dd, yyyy hh:mm tt")</dd>
	</dl>
</div>

@using (Html.BeginForm())
{
	@Html.AntiForgeryToken()
	<div class="form-actions no-color">
		<input type="submit" value="Delete" class="btn btn-danger" />
		@Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-default" })
		@Html.ActionLink("Back to Dashboard", "Dashboard", "Dashboard", null, new { @class = "btn btn-secondary" })
	</div>
}