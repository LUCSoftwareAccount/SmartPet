@model SmartPet.Models.MedicationLogs

@{
	ViewBag.Title = "Edit Medication Log";
}

<h2>Edit Medication Log</h2>

@using (Html.BeginForm())
{
	@Html.AntiForgeryToken()
	@Html.HiddenFor(model => model.id)

	<div class="form-group">
		@Html.Label("Medication")
		@Html.TextBoxFor(model => model.medicationName, new { @class = "form-control" })
		@Html.ValidationMessageFor(model => model.medicationName, "", new { @class = "text-danger" })
	</div>

	<div class="form-group">
		@Html.Label("Amount")
		@Html.TextBoxFor(model => model.amount, new { @class = "form-control" })
		@Html.ValidationMessageFor(model => model.amount, "", new { @class = "text-danger" })
	</div>

	<div class="form-group">
		@Html.Label("Administered At")
		@Html.TextBoxFor(model => model.administeredAt, new { @class = "form-control", type = "datetime-local" })
		@Html.ValidationMessageFor(model => model.administeredAt, "", new { @class = "text-danger" })
	</div>

	<button type="submit" class="btn btn-success">Save</button>
	@Html.ActionLink("Back to Dashboard", "Dashboard", "Dashboard", null, new { @class = "btn btn-secondary" })
}