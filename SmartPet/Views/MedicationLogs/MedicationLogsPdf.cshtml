@model IEnumerable<SmartPet.Models.MedicationLogs>

@{
	Layout = null;
}

<h2>Medication Logs Report</h2>

<table border="1" cellpadding="8" cellspacing="0" style="width:100%; border-collapse:collapse;">
	<tr>
		<th>Pet</th>
		<th>Medication</th>
		<th>Amount</th>
		<th>Administered At</th>
	</tr>

	@foreach (var item in Model)
	{
		<tr>
			<td>@(item.Pet != null ? item.Pet.name : "No pet selected")</td>
			<td>@item.medicationName</td>
			<td>@item.amount</td>
			<td>@item.administeredAt.ToString("MMM dd, yyyy hh:mm tt")</td>
		</tr>
	}
</table>