@model SmartPet.Models.FeedingLogs

<h2>Delete Feeding Log</h2>

<p>Are you sure you want to delete this?</p>

<p>Brand: @Model.brand</p>
<p>Food Type: @Model.foodType</p>
<p>Amount: @Model.amount</p>
<p>Fed At: @Model.fedAt</p>
<p>Pet ID: @Model.petId</p>

@using (Html.BeginForm())
{
	<button type="submit">Delete</button>
}