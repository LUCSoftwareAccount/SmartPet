@{
    Layout = null;
}

@model SmartPet.Models.ReminderViewModel

@{
    ViewBag.Title = "Edit Reminder";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f4f7fc;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 800px;
            margin-top: 50px;
        }

        h2 {
            color: #1e3a8a;
            margin-bottom: 20px;
        }

        .form-container {
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .form-group label {
            font-weight: bold;
            color: #333;
        }

        .form-group input, .form-group textarea, .form-group select {
            border-radius: 8px;
            border: 1px solid #ccc;
            padding: 12px;
            width: 100%;
            font-size: 14px;
            color: #333;
            background-color: #fafafa;
        }

        .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
            border-color: #2563eb;
            outline: none;
            background-color: #f0f9ff;
        }

        .form-group textarea {
            resize: vertical;
        }

        .form-group .validation-message {
            color: #e53e3e;
            font-size: 14px;
        }

        .form-container .btn {
            width: 100%;
            padding: 12px;
            font-size: 16px;
            border-radius: 8px;
        }

        .btn-primary {
            background-color: #2563eb;
            border: none;
        }

        .btn-primary:hover {
            background-color: #1d4ed8;
        }

        .btn-default {
            background-color: #e2e8f0;
            border: none;
            color: #1e3a8a;
        }

        .btn-default:hover {
            background-color: #cbd5e1;
        }

            .form-container {
                padding: 20px;
            }

            .form-container .btn {
                width: 100%;
                margin-top: 15px;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="form-container">
        <h2>Edit Reminder</h2>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                @Html.LabelFor(model => model.Message)
                @Html.TextAreaFor(model => model.Message, new { @class = "form-control", rows = 4 })
                @Html.ValidationMessageFor(model => model.Message, "", new { @class = "validation-message" })
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.DueAt)
                @Html.TextBoxFor(model => model.DueAt, "{0:yyyy-MM-dd HH:mm}", new { @class = "form-control", type = "datetime-local" })
                @Html.ValidationMessageFor(model => model.DueAt, "", new { @class = "validation-message" })
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.PetId, "Select Pet")
                @Html.DropDownListFor(model => model.PetId, (SelectList)ViewBag.Pets, "Select a Pet", new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.PetId, "", new { @class = "validation-message" })
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
        }

        <!-- Cancel or Go Back -->
        <a href="@Url.Action("Dashboard", "Dashboard")" class="btn btn-default" style="margin-top: 15px;">Cancel</a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>