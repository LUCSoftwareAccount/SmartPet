@{
    Layout = null;
}

@model SmartPet.Models.Reminder

@{
    ViewBag.Title = "Delete Reminder";
}

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewBag.Title</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" />
	<style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f4f7fc;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 800px;
            margin-top: 50px;
        }

        h2 {
            color: #1e3a8a;
            margin-bottom: 20px;
        }

        .confirmation-box {
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .confirmation-box strong {
            color: #333;
            font-size: 16px;
        }

        .confirmation-box p {
            font-size: 14px;
            color: #555;
        }

        .confirmation-box .btn {
            width: 48%;
            margin-top: 20px;
        }

        .confirmation-box .btn-danger {
            background-color: #e53e3e;
            border: none;
        }

        .confirmation-box .btn-danger:hover {
            background-color: #c53030;
        }

        .confirmation-box .btn-default {
            background-color: #e2e8f0;
            border: none;
            color: #1e3a8a;
        }

        .confirmation-box .btn-default:hover {
            background-color: #cbd5e1;
        }

        .cancel-btn {
            margin-left: 8px;
        }

            .confirmation-box {
                padding: 20px;
            }

            .confirmation-box .btn {
                width: 100%;
                margin-top: 15px;
            }

            .cancel-btn {
                margin-left: 0;
            }
        }
	</style>
</head>
<body>

	<div class="container">
		<div class="confirmation-box">
			<h2>Delete Reminder</h2>
			<p>Are you sure you want to delete the following reminder?</p>
			<div>
				<strong>Message:</strong> @Model.message
				<br />
				<strong>Due Date:</strong> @Model.dueAt.ToString("MMM dd, yyyy h:mm tt")
			</div>

			<form action="@Url.Action("Delete", "Reminder", new { id = Model.id })" method="post">
				@Html.AntiForgeryToken()
				<button type="submit" class="btn btn-danger">Delete</button>
				<a href="@Url.Action("Dashboard", "Dashboard")" class="btn btn-default cancel-btn">Cancel</a>
			</form>
		</div>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>