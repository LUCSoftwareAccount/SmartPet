@{
	ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">

<link rel="stylesheet" href=" /css/Login.css" />

<div class="login-form-container">

	<img src="~/images/SmartPet_png.png"
		      alt="SmartPet logo"
			  class="img"/>

	<h1 class="login-title">Login to SmartPet</h1>

	@if (ViewBag.Error != null)
	{
		<p>@ViewBag.Error</p>
	}

	<form asp-controller="User" asp-action="Login" method="post" class="login-form">
		@Html.AntiForgeryToken()

		<label>Email</label>
		<input type="email"
			           id="email"
			           name="Email"
			           placeholder="Enter your email"
			           required />

		<label>Password</label>
		<input type="password"
			           id="password"
			           name="Password"
			           placeholder="Enter your password"
			           required />

		<button type="submit">Login</button>
	</form>

	<p>
		Don’t have an account?
		<a asp-controller="User" asp-action="Registration" > Register here</a>
	</p>

</div>
