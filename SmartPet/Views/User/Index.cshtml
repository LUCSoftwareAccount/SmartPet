
@model IEnumerable<User>

<h1>Users</h1>
<p>
	<a href="@Url.Action("Create", "User")" class="btn btn-primary">Create New User</a>
</p>

<table class="table">
	<thead>
		<tr>
			<th>First Name</th>
			<th>Last Name</th>
			<th>Email</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var user in Model)
		{
			<tr>
				<td>@user.FirstName</td>
				<td>@user.LastName</td>
				<td>@user.Email</td>
				<td>
					<a href="@Url.Action("Edit", "User", new { id = user.Id })" class="btn btn-warning">Edit</a>
					<a href="@Url.Action("Delete", "User", new { id = user.Id })" class="btn btn-danger">Delete</a>
				</td>
			</tr>
		}
	</tbody>
</table>

