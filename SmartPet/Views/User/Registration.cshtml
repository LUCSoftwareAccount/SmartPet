@model SmartPet.Models.User

@{
	ViewBag.Title = "Register";
}

<link rel="stylesheet" href="~/Content/Register.css" />

<div class="register-page">
	<div class="register-container fade-in">
		<img src="~/images/petnote-logo-new.png" alt="Petnote Logo" class="logo" />

		<h1 class="register-title">Create Your Account</h1>
		<p class="register-subtitle">Join SmartPet today.</p>

		@Html.ValidationSummary(true, "", new { @class = "error-message" })

		@using (Html.BeginForm("Registration", "User", FormMethod.Post, new { @class = "register-form" }))
		{
			@Html.AntiForgeryToken()


			<div class="form-group">
				<label for="username">Username</label>
				@Html.TextBoxFor(m => m.username, new
				{
					@class = "form-input",
					placeholder = "Enter your username"
				})
			</div>

			<div class="form-group">
				<label for="email">Email</label>
				@Html.TextBoxFor(m => m.email, new
				{
					@class = "form-input",
					placeholder = "Enter your email",
					type = "email"
				})
			</div>

			<div class="form-group">
				<label for="passwordHash">Password</label>
				@Html.PasswordFor(m => m.passwordHash, new
				{
					@class = "form-input",
					placeholder = "Enter your password"
				})
			</div>

			<button type="submit" class="register-btn">Register</button>
		}

		<p class="login-text">
			Already have an account?
			@Html.ActionLink("Login here", "Login", "User", null, new { @class = "login-link" })
		</p>
	</div>
</div>