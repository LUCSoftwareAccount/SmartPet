@model SmartPet.Models.DashboardViewModel

@{
	ViewBag.Title = "Dashboard";
}

<style>
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
		font-family: Arial, Helvetica, sans-serif;
	}

	body {
		background-color: #f6f8fc;
	}

	.dashboard-container {
		max-width: 1200px;
		margin: 30px auto;
		padding: 20px;
	}

	.dashboard-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		margin-bottom: 25px;
		gap: 15px;
	}

		.dashboard-header h1 {
			color: #1e3a8a;
			font-size: 32px;
			margin-bottom: 5px;
		}

		.dashboard-header p {
			color: #6b7280;
			font-size: 15px;
		}

	.dashboard-actions {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}

	.action-button {
		display: inline-block;
		text-decoration: none;
		padding: 10px 16px;
		border-radius: 10px;
		font-size: 14px;
		font-weight: bold;
		transition: 0.2s ease;
		border: none;
		cursor: pointer;
	}

	.action-button-primary {
		background-color: #2563eb;
		color: white;
	}

		.action-button-primary:hover {
			background-color: #1d4ed8;
		}

	.action-button-secondary {
		background-color: #e0e7ff;
		color: #1e3a8a;
	}

		.action-button-secondary:hover {
			background-color: #c7d2fe;
		}

	.summary-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 18px;
		margin-bottom: 25px;
	}

	.card {
		background: white;
		border-radius: 16px;
		padding: 20px;
		box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
	}

	.card-label {
		font-size: 14px;
		color: #6b7280;
		margin-bottom: 10px;
	}

	.card-value {
		font-size: 28px;
		font-weight: bold;
		color: #111827;
	}

	.card-subtext {
		margin-top: 8px;
		font-size: 13px;
		color: #6b7280;
	}

	.main-grid {
		display: grid;
		grid-template-columns: 1.3fr 1fr;
		gap: 20px;
		margin-bottom: 25px;
	}

	.section-title {
		font-size: 20px;
		margin-bottom: 15px;
		color: #111827;
	}

	.item-list {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.item-box {
		border: 1px solid #e5e7eb;
		border-radius: 12px;
		padding: 14px;
		background-color: #fafcff;
	}

		.item-box h4 {
			margin-bottom: 6px;
			color: #111827;
			font-size: 16px;
		}

		.item-box p {
			color: #4b5563;
			font-size: 14px;
			line-height: 1.5;
		}

	.tag {
		display: inline-block;
		margin-top: 8px;
		padding: 5px 10px;
		border-radius: 999px;
		font-size: 12px;
		font-weight: bold;
	}

	.tag-blue {
		background-color: #dbeafe;
		color: #1d4ed8;
	}

	.tag-green {
		background-color: #dcfce7;
		color: #166534;
	}

	.tag-yellow {
		background-color: #fef3c7;
		color: #92400e;
	}

	.tag-purple {
		background-color: #ede9fe;
		color: #6d28d9;
	}

	.empty-box {
		border: 2px dashed #cbd5e1;
		border-radius: 14px;
		background-color: #f8fbff;
		padding: 30px 20px;
		text-align: center;
		color: #64748b;
	}

		.empty-box h4 {
			font-size: 18px;
			margin-bottom: 10px;
			color: #334155;
		}

		.empty-box p {
			font-size: 14px;
			line-height: 1.6;
			max-width: 420px;
			margin: 0 auto;
		}

	.pet-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
	}

	.pet-card {
		background: white;
		border-radius: 16px;
		padding: 20px;
		box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
	}

	.pet-header {
		display: flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 14px;
	}

	.pet-avatar {
		width: 60px;
		height: 60px;
		border-radius: 50%;
		background: #dbeafe;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 24px;
		overflow: hidden;
	}

		.pet-avatar img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

	.pet-card h3 {
		margin-bottom: 4px;
		color: #111827;
	}

	.pet-card p {
		color: #4b5563;
		font-size: 14px;
	}

	.pet-details {
		margin-top: 12px;
		padding-left: 18px;
	}

		.pet-details li {
			margin-bottom: 8px;
			color: #4b5563;
			font-size: 14px;
		}

	.pet-card-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 12px;
	}

	@@media (max-width: 1000px) {
		.main-grid,
		.pet-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<div class="dashboard-container">
	<div class="dashboard-header">
		<div>
			<h1>SmartPet Dashboard</h1>
			<p>View recent health logs, upcoming reminders, and pet records in one place.</p>
		</div>

		<div class="dashboard-actions">
			@Html.ActionLink("Activities Log", "Index", "Activities", null, new { @class = "action-button action-button-primary" })
			@Html.ActionLink("Add Activity", "Create", "Activities", null, new { @class = "action-button action-button-secondary" })

			@using (Html.BeginForm("Logout", "User", FormMethod.Post))
			{
				@Html.AntiForgeryToken()
				<button type="submit" class="action-button action-button-secondary">Logout</button>
			}
		</div>
	</div>

	<div class="summary-grid">
		<div class="card">
			<div class="card-label">Total Pets</div>
			<div class="card-value">@Model.TotalPets</div>
			<div class="card-subtext">Pet profiles currently stored in the system.</div>
		</div>

		<div class="card">
			<div class="card-label">Upcoming Reminders</div>
			<div class="card-value">@Model.UpcomingReminders.Count</div>
			<div class="card-subtext">Upcoming reminders currently scheduled.</div>
		</div>

		<div class="card">
			<div class="card-label">Recent Vaccines</div>
			<div class="card-value">@Model.RecentVaccines.Count</div>
			<div class="card-subtext">Latest vaccine records from the database.</div>
		</div>

		<div class="card">
			<div class="card-label">Medication Logs</div>
			<div class="card-value">@Model.TotalMedicationLogs</div>
			<div class="card-subtext">Medication administration records in the system.</div>
		</div>
	</div>

	<div class="main-grid">
		<div class="card">
			<h2 class="section-title">Recent Health Logs</h2>

			@if (Model.RecentVaccines.Any() || Model.RecentNotes.Any() || Model.RecentMedicationLogs.Any())
			{
				<div class="item-list">
					@foreach (var medLog in Model.RecentMedicationLogs)
					{
						<div class="item-box">
							<h4>Medication: @medLog.MedicationName</h4>
							<p>Amount: @medLog.Amount</p>
							<span class="tag tag-yellow">@medLog.AdministeredAt.ToString("MMM dd, yyyy h:mm tt")</span>
						</div>
					}

					@foreach (var vaccine in Model.RecentVaccines)
					{
						<div class="item-box">
							<h4>Vaccine: @vaccine.name</h4>
							<p>Vet: @vaccine.vetName</p>
							<span class="tag tag-green">@vaccine.administeredOn.ToString("MMM dd, yyyy")</span>
						</div>
					}

					@foreach (var note in Model.RecentNotes)
					{
						<div class="item-box">
							<h4>Pet Note</h4>
							<p>@note.content</p>
							<span class="tag tag-blue">@note.createdAt.ToString("MMM dd, yyyy")</span>
						</div>
					}
				</div>
			}
			else
			{
				<div class="empty-box">
					<h4>No health logs yet</h4>
					<p>Medication logs, vaccine records, and notes will appear here once users begin entering records.</p>
				</div>
			}
		</div>

		<div class="card">
			<h2 class="section-title">Upcoming Reminders</h2>

			@if (Model.UpcomingReminders.Any())
			{
				<div class="item-list">
					@foreach (var reminder in Model.UpcomingReminders)
					{
						<div class="item-box">
							<h4>@reminder.reminderType</h4>
							<p>@reminder.message</p>
							<span class="tag tag-purple">@reminder.dueAt.ToString("MMM dd, yyyy h:mm tt")</span>
						</div>
					}
				</div>
			}
			else
			{
				<div class="empty-box">
					<h4>No reminders scheduled</h4>
					<p>Upcoming reminders will appear here after they are added to the system.</p>
				</div>
			}
		</div>
	</div>

	<div class="card" style="margin-bottom: 25px;">
		<h2 class="section-title">Quick Actions</h2>
		<div class="dashboard-actions">
			@Html.ActionLink("View Activities Log", "Index", "Activities", null, new { @class = "action-button action-button-primary" })
			@Html.ActionLink("Create New Activity", "Create", "Activities", null, new { @class = "action-button action-button-secondary" })
			@Html.ActionLink("Add Pet", "Create", "Pet", null, new { @class = "action-button action-button-secondary" })
			@Html.ActionLink("Create Medication Logs", "Create", "MedicationLogs", null, new { @class = "action-button action-button-secondary" })
			@Html.ActionLink("Create Feeding Log", "Create", "FeedingLogs", null, new { @class = "action-button action-button-secondary" })
			@Html.ActionLink("View Feeding Logs", "Index", "FeedingLogs", null, new { @class = "action-button action-button-secondary" })
		</div>
	</div>

	<h2 class="section-title" style="margin-bottom: 15px;">Summary of Each Pet’s Record</h2>

	@if (Model.Pets.Any())
	{
		<div class="pet-grid">
			@foreach (var pet in Model.Pets)
			{
				<div class="pet-card">
					<div class="pet-header">
						<div class="pet-avatar">
							@if (!string.IsNullOrEmpty(pet.photoUrl))
							{
								<img src="@pet.photoUrl" alt="@pet.name" />
							}
							else
							{
								<span>🐾</span>
							}
						</div>

						<div>
							<h3>@pet.name</h3>
							<p>@pet.type</p>
						</div>
					</div>

					<div class="pet-card-actions">
						@Html.ActionLink("Details", "Details", "Pet", new { id = pet.id }, new { @class = "action-button action-button-secondary" })
						@Html.ActionLink("Edit", "Edit", "Pet", new { id = pet.id }, new { @class = "action-button action-button-secondary" })
						@Html.ActionLink("Delete", "Delete", "Pet", new { id = pet.id }, new { @class = "action-button action-button-secondary" })
						@Html.ActionLink("Notes", "Index", "Note", new { petId = pet.id }, new { @class = "action-button action-button-secondary" })
						@Html.ActionLink("View Medication Logs", "Index", "MedicationLogs", new { petId = pet.id }, new { @class = "action-button action-button-secondary" })
						@Html.ActionLink("View Feeding Logs", "Index", "FeedingLogs", new { petId = pet.id }, new { @class = "action-button action-button-secondary" })
					</div>

					<ul class="pet-details">
						<li><strong>Breed:</strong> @pet.breed</li>
						<li><strong>Gender:</strong> @pet.gender</li>
						<li><strong>Weight:</strong> @pet.weight</li>
						<li><strong>Birthdate:</strong> @(pet.Birthdate.HasValue ? pet.Birthdate.Value.ToString("MMM dd, yyyy") : "")</li>
						<li><strong>Microchip ID:</strong> @pet.microchipId</li>
					</ul>
				</div>
			}
		</div>
	}
	else
	{
		<div class="card">
			<div class="empty-box">
				<h4>No pet profiles yet</h4>
				<p>Pet summaries will appear here once users register pets in the app.</p>
			</div>
		</div>
	}
</div>