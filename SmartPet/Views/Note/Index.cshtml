@model IEnumerable<SmartPet.Models.Note>

<h2>Notes for @ViewBag.PetName</h2>

<p>
	@Html.ActionLink("Create New Note", "Create", new { petId = ViewBag.PetId })
</p>

<table class="table">
	<tr>
		<th>Content</th>
		<th>Created At</th>
		<th>Updated At</th>
		<th></th>
	</tr>

	@foreach (var item in Model)
	{
		<tr>
			<td>@item.content</td>
			<td>@item.createdAt.ToString("yyyy-MM-dd HH:mm")</td>
			<td>@(item.updatedAt.HasValue ? item.updatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
			<td>
				@Html.ActionLink("Edit", "Edit", new { id = item.id }) |
				@Html.ActionLink("Details", "Details", new { id = item.id }) |
				@Html.ActionLink("Delete", "Delete", new { id = item.id }) |
				@Html.ActionLink("Notes", "Index", "Note", new { petId = item.id }, null)
			</td>
		</tr>
	}
</table>

<p>
	@Html.ActionLink("Back to Pets", "Index", "Pet")
</p>

