@model SmartPet.Models.Note

@{
	ViewBag.Title = "Note Details";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Note Details</h2>

<table class="table">
	<tr>
		<th>Content</th>
		<th>Created At</th>
		<th>Updated At</th>
		<th>Actions</th>
	</tr>
	<tr>
		<td>@Model.content</td>
		<td>@Model.createdAt.ToString("yyyy-MM-dd HH:mm")</td>
		<td>@(Model.updateAt.HasValue ? Model.updateAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
		<td>
			@Html.ActionLink("Edit", "Edit", new { id = Model.id }, new { @class = "btn btn-info btn-sm" })
			@Html.ActionLink("Back to List", "Index", new { petId = Model.petId }, new { @class = "btn btn-default btn-sm" })
		</td>
	</tr>
</table>

