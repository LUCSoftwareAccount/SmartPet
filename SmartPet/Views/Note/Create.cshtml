@model SmartPet.Models.Note

@{
	ViewBag.Title = "Create Note";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Create Note</h2>

@using (Html.BeginForm())
{
	@Html.AntiForgeryToken()
	@Html.HiddenFor(model => model.petId)

	<div class="form-horizontal">
		<hr />

		<div class="form-group">
			@Html.LabelFor(model => model.content, new { @class = "control-label col-md-2" })
			<div class="col-md-10">
				@Html.TextAreaFor(model => model.content, new { @class = "form-control", rows = 5 })
				@Html.ValidationMessageFor(model => model.content, "", new { @class = "text-danger" })
			</div>
		</div>

		<div class="form-group">
			<div class="col-md-offset-2 col-md-10">
				<input type="submit" value="Create" class="btn btn-success" />
			</div>
		</div>
	</div>
}

<br />
@Html.ActionLink("Back to List", "Index", new { petId = Model.petId }, new { @class = "btn btn-default" })